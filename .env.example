# ============================================================
# The Syndicate — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Claude Code will read these automatically if you use direnv
# or source them in your shell profile.
# ============================================================

# ── Odds & Betting Data ──────────────────────────────────────

# The Odds API (required for odds-scraper, line-shopper, arb-scanner)
# Free tier: 500 requests/month. Sign up: https://the-odds-api.com
ODDS_API_KEY=

# Polymarket CLOB API (optional — no auth required for reads)
# Public endpoints at clob.polymarket.com and gamma-api.polymarket.com
# Set this only if you need authenticated write access for placing trades
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# OddsJam (optional — paid, for premium odds comparison)
# Sign up: https://oddsjam.com
ODDSJAM_API_KEY=

# ── Sports Statistics ─────────────────────────────────────────

# Sportradar (optional — paid, for professional-grade stats)
# Most stats agents use free APIs (nba_api, nfl_data_py, pybaseball)
# which require no keys.
SPORTRADAR_API_KEY=

# College Football Data API (optional — free tier available)
# Sign up: https://collegefootballdata.com
CFBD_API_KEY=

# ── Weather ──────────────────────────────────────────────────

# Open-Meteo (no key required — free, no auth)
# Used by: meteorologist agent
# Endpoint: https://api.open-meteo.com/v1/forecast

# ── Alerts & Notifications ───────────────────────────────────

# Slack webhook (optional — for arb alerts, pick reports)
SLACK_WEBHOOK_URL=

# Pushover mobile notifications (optional)
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=

# ── Database ─────────────────────────────────────────────────

# Override default database path (optional)
# Default: ~/.syndicate/bankroll.db
SYNDICATE_DB_PATH=
